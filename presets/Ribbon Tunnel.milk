per_frame_1=q1=q1+0.004+bass*0.003;
per_frame_2=q2=q2*0.90+mid_att*0.18;
per_frame_3=q3=q3+0.006+treb_att*0.003;
per_frame_4=q4=q4+0.010+bass_att*0.005;
