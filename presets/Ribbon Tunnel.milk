wave_0_per_frame1=t1=q1; t2=q2; t3=q3;
wave_0_per_point1=s=sample*6.2832;
wave_0_per_point2=R=0.26+0.08*sin(s*4+t2);
wave_0_per_point3=ri=0.06+treb_att*0.04;
wave_0_per_point4=xp=(R+ri*cos(s*8+t1*2))*cos(s);
wave_0_per_point5=yp=(R+ri*cos(s*8+t1*2))*sin(s);
wave_0_per_point6=zp=ri*sin(s*8+t1*2);
wave_0_per_point7=ang=t3;
wave_0_per_point8=xq=xp*cos(ang)-zp*sin(ang); zq=xp*sin(ang)+zp*cos(ang);
wave_0_per_point9=xp=xq; zp=zq+2.2;
wave_0_per_point10=x=xp/zp+0.5; y=yp/zp*1.333+0.5;
wave_0_per_point11=r=0.30+0.10*sin(s*2); g=0.75+0.20*sin(s+t2); b=1.00; a=0.16+0.18*above(zp,0.05);
