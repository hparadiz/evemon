wave_1_per_point3=x=0.5+cos(ang)*rad;
wave_1_per_point4=y=0.5+sin(ang)*rad;
wave_1_per_point5=r=0.30; g=0.70+value*0.20; b=1.00; a=0.08+value*0.15;
