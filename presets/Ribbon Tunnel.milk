per_frame_6=decay=0.942+bass_att*0.004;
per_frame_7=warp=0.0008+mid_att*0.0018;
per_frame_8=zoom=1.00008+0.00008*sin(time*0.1);
per_pixel_1=rot=rot+sin((x-0.5)*8+time*0.2)*0.004*(1-rad);
per_pixel_2=zoom=zoom+0.0008/(1+abs(x-0.5)+abs(y-0.5));
