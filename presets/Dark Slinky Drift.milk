per_frame_1=q1 = q1 + bass * 0.006 + 0.0012;
per_frame_2=q2 = q2 + 0.0025 + treb_att * 0.003;
per_frame_3=q3 = q3 * 0.90 + bass * 0.18;
per_frame_4=q4 = 0.80 + sin(q1 * 0.5) * 0.40;
per_frame_5=zoom = 1.00005 + bass_att * 0.00020;
per_frame_6=rot = 0;
per_frame_7=warp = 0.00005 + mid_att * 0.00020;
per_frame_8=decay = 0.900 + bass_att * 0.004;
per_frame_9=cx = 0.500;
per_frame_10=cy = 0.500;
per_frame_11=q5 = time*0.11;
per_frame_12=q6 = time*0.07;
per_frame_13=ob_g = 0.010 + 0.010*(0.5 + 0.5*sin(q5));
per_frame_14=ob_b = 0.030 + 0.040*(0.5 + 0.5*cos(q6));
per_frame_15=ib_g = 0.006 + 0.008*(0.5 + 0.5*cos(q5*0.8));
per_frame_16=ib_b = 0.016 + 0.018*(0.5 + 0.5*sin(q6*1.2));
per_frame_17=dx = sin(q5)*0.00018;
per_frame_18=dy = cos(q6)*0.00014;
per_frame_19=warp = 0.00004 + 0.00008*(0.5 + 0.5*sin(q5*0.7)) + mid_att*0.00018;
per_pixel_1=rot = rot;
per_pixel_2=zoom = zoom;
