wave_0_per_frame1=t1 = t1 + bass * 0.005 + 0.0008;
wave_0_per_frame2=t2 = 0.22 + bass_att * 0.10;
wave_0_per_frame3=t3 = q1 * 0.28;
wave_0_per_point1=smp = sample * 6.2832;
wave_0_per_point2=R = t2;
wave_0_per_point3=ri = 0.07 + treb_att * 0.04;
wave_0_per_point4=v = smp * 8.0 + t1 * 3.5;
wave_0_per_point5=xp = (R + ri*cos(v)) * cos(smp);
wave_0_per_point6=yp = (R + ri*cos(v)) * sin(smp);
wave_0_per_point7=zp = ri * sin(v);
wave_0_per_point8=angy = t3;
wave_0_per_point9=xq = xp*cos(angy) - zp*sin(angy); zq = xp*sin(angy) + zp*cos(angy);
wave_0_per_point10=xp = xq; zp = zq;
wave_0_per_point11=angx = t1 * 0.18;
wave_0_per_point12=yq = yp*cos(angx) - zp*sin(angx); zq = yp*sin(angx) + zp*cos(angx);
wave_0_per_point13=yp = yq; zp = zq;
wave_0_per_point14=zp = zp + 2.4;
wave_0_per_point15=x = xp/zp + 0.5;
wave_0_per_point16=y = yp/zp*1.333 + 0.5;
wave_0_per_point17=hue = q2 + smp * 0.04;
wave_0_per_point18=h = 6*(hue - int(hue));
wave_0_per_point19=sw1=below(h,1); sw2=(1-sw1)*below(h,2); sw3=(1-sw1)*(1-sw2)*below(h,3);
wave_0_per_point20=sw4=(1-sw1)*(1-sw2)*(1-sw3)*below(h,4); sw6=above(h,5); sw5=(1-sw1)*(1-sw2)*(1-sw3)*(1-sw4)*(1-sw6);
wave_0_per_point21=r = sw1 + sw2*(2-h) + sw5*(h-4) + sw6;
wave_0_per_point22=g = sw1*h + sw2 + sw3 + sw4*(4-h);
wave_0_per_point23=b = sw3*(h-2) + sw4 + sw5 + sw6*(6-h);
wave_0_per_point24=a = 0.80 * above(zp, 0.05);
