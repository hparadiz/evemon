wave_1_per_frame1=t1 = q1 * 0.45;
wave_1_per_point1=angle = sample * 6.2832 + t1;
wave_1_per_point2=mag = value * (0.14 + bass_att * 0.08);
wave_1_per_point3=x = 0.5 + cos(angle) * (0.28 + mag);
wave_1_per_point4=y = 0.5 + sin(angle) * (0.28 + mag);
wave_1_per_point5=hue = q2 + sample * 0.5;
wave_1_per_point6=h = 6*(hue - int(hue));
wave_1_per_point7=sw1=below(h,1); sw2=(1-sw1)*below(h,2); sw3=(1-sw1)*(1-sw2)*below(h,3);
wave_1_per_point8=sw4=(1-sw1)*(1-sw2)*(1-sw3)*below(h,4); sw6=above(h,5); sw5=(1-sw1)*(1-sw2)*(1-sw3)*(1-sw4)*(1-sw6);
wave_1_per_point9=r = sw1 + sw2*(2-h) + sw5*(h-4) + sw6;
wave_1_per_point10=g = sw1*h + sw2 + sw3 + sw4*(4-h);
wave_1_per_point11=b = sw3*(h-2) + sw4 + sw5 + sw6*(6-h);
wave_1_per_point12=a = 0.60 * value;
